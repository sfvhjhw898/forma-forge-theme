{{ 'forma-brand.css' | asset_url | stylesheet_tag }}

<section class="forma-section fma-wrap" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="fma-inner">

    <header class="fma-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="fo-label fma-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="fma-heading">{{ section.settings.heading | default: 'Our Materials' }}</h2>
      {%- if section.settings.body != blank -%}
        <p class="fma-body">{{ section.settings.body }}</p>
      {%- endif -%}
    </header>

    <div class="fma-grid">
      {%- for block in section.blocks -%}
        <article class="fma-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="fma-card__img-wrap">
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.image.alt | default: block.settings.name | escape }}"
                loading="lazy"
                width="400" height="500"
                class="fma-card__img">
            </div>
          {%- else -%}
            <div class="fma-card__swatch" style="background: {{ block.settings.swatch_color | default: '#D4D4CF' }};"></div>
          {%- endif -%}
          <div class="fma-card__info">
            <p class="fo-label fma-card__origin">{{ block.settings.origin | default: 'Sustainably Sourced' }}</p>
            <h3 class="fma-card__name">{{ block.settings.name | default: 'Material' }}</h3>
            {%- if block.settings.desc != blank -%}
              <p class="fma-card__desc">{{ block.settings.desc }}</p>
            {%- endif -%}
            <dl class="fma-card__specs">
              {%- if block.settings.spec_1_label != blank -%}
                <div class="fma-spec-row">
                  <dt>{{ block.settings.spec_1_label }}</dt>
                  <dd>{{ block.settings.spec_1_value }}</dd>
                </div>
              {%- endif -%}
              {%- if block.settings.spec_2_label != blank -%}
                <div class="fma-spec-row">
                  <dt>{{ block.settings.spec_2_label }}</dt>
                  <dd>{{ block.settings.spec_2_value }}</dd>
                </div>
              {%- endif -%}
            </dl>
          </div>
        </article>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
.fma-wrap { background: var(--fo-white); }
.fma-inner { max-width: 1200px; margin: 0 auto; padding: 0 48px; }

.fma-header { margin-bottom: 64px; max-width: 560px; }
.fma-eyebrow { margin: 0 0 16px; }
.fma-heading {
  font-family: var(--fo-font-head);
  font-size: clamp(28px, 4vw, 52px);
  font-weight: 300;
  color: var(--fo-black);
  margin: 0 0 20px;
  letter-spacing: -.02em;
}
.fma-body {
  font-size: 15px;
  line-height: 1.8;
  color: var(--fo-mid);
  margin: 0;
}

.fma-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1px;
  background: var(--fo-border);
  border: 1px solid var(--fo-border);
}
.fma-card {
  background: var(--fo-white);
  display: flex;
  flex-direction: column;
  transition: background var(--fo-trans);
}
.fma-card:hover { background: var(--fo-warm); }

.fma-card__img-wrap {
  overflow: hidden;
  aspect-ratio: 4 / 5;
  background: var(--fo-light);
}
.fma-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 500ms ease;
}
.fma-card:hover .fma-card__img { transform: scale(1.04); }

.fma-card__swatch {
  aspect-ratio: 4 / 5;
}
.fma-card__info { padding: 24px; flex: 1; }
.fma-card__origin { margin: 0 0 8px; }
.fma-card__name {
  font-family: var(--fo-font-head);
  font-size: 20px;
  font-weight: 400;
  color: var(--fo-black);
  margin: 0 0 12px;
}
.fma-card__desc {
  font-size: 13px;
  line-height: 1.75;
  color: var(--fo-mid);
  margin: 0 0 20px;
}
.fma-card__specs {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin: 0;
  padding-top: 16px;
  border-top: 1px solid var(--fo-border);
}
.fma-spec-row {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  font-family: var(--fo-mono);
}
.fma-spec-row dt { color: var(--fo-mid); }
.fma-spec-row dd { color: var(--fo-black); margin: 0; }

@media (prefers-reduced-motion: reduce) {
  .fma-card__img { transition: none; }
}
@media (max-width: 640px) {
  .fma-inner { padding: 0 20px; }
  .fma-grid { grid-template-columns: 1fr 1fr; }
}
</style>

{% schema %}
{
  "name": "FORMA Materials",
  "tag": "section",
  "class": "forma-section-materials",
  "settings": [
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow", "default": "Craftsmanship" },
    { "type": "text",     "id": "heading", "label": "Heading", "default": "Our Materials" },
    { "type": "textarea", "id": "body",    "label": "Body text" },
    { "type": "range", "id": "padding_top",    "label": "Padding top",    "min": 0, "max": 120, "step": 8, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 8, "default": 80 }
  ],
  "blocks": [{
    "type": "material",
    "name": "Material",
    "settings": [
      { "type": "image_picker", "id": "image",        "label": "Image" },
      { "type": "color",        "id": "swatch_color", "label": "Swatch color (if no image)", "default": "#C8B8A8" },
      { "type": "text",         "id": "origin",       "label": "Origin / certification" },
      { "type": "text",         "id": "name",         "label": "Material name", "default": "Solid Oak" },
      { "type": "textarea",     "id": "desc",         "label": "Description" },
      { "type": "text",         "id": "spec_1_label", "label": "Spec 1 label" },
      { "type": "text",         "id": "spec_1_value", "label": "Spec 1 value" },
      { "type": "text",         "id": "spec_2_label", "label": "Spec 2 label" },
      { "type": "text",         "id": "spec_2_value", "label": "Spec 2 value" }
    ]
  }],
  "presets": [{
    "name": "FORMA Materials",
    "blocks": [
      { "type": "material", "settings": { "name": "Solid Oak",     "origin": "FSC Certified", "desc": "Slow-grown European oak, selected for consistent grain. Finished with natural hard-wax oil.", "spec_1_label": "Origin", "spec_1_value": "Germany", "spec_2_label": "Finish", "spec_2_value": "Hard-wax oil" } },
      { "type": "material", "settings": { "name": "Raw Concrete",  "origin": "UK Fabricated", "desc": "GFRC panels cast in our London workshop. Each piece unique — no two alike.", "spec_1_label": "Weight", "spec_1_value": "Light", "spec_2_label": "Lead time", "spec_2_value": "3 weeks" } },
      { "type": "material", "settings": { "name": "Cold Steel",    "origin": "Recycled 90%",  "desc": "Powder-coated structural steel in 14 standard colours. Custom RAL available.", "spec_1_label": "Gauge", "spec_1_value": "3mm", "spec_2_label": "Options", "spec_2_value": "14 colours" } }
    ]
  }]
}
{% endschema %}
