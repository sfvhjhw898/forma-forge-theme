{%- style -%}
  .forma-banner {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .forma-banner__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .forma-banner__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .forma-banner__background-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, #E8E4DF 0%, #D5CFC8 100%);
  }

  .forma-banner__background::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to bottom, rgba(0,0,0,0.08) 0%, transparent 30%, rgba(240,237,232,0.85) 100%);
    z-index: 1;
  }

  .forma-banner__content {
    position: relative;
    z-index: 10;
    width: 100%;
    padding: 0 60px 60px;
  }

  .forma-banner__heading-wrapper {
    position: relative;
    margin-bottom: 2rem;
  }

  .forma-heading-outline,
  .forma-heading-filled {
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 200;
    font-size: clamp(5rem, 9vw, 10rem);
    line-height: 0.88;
    letter-spacing: -0.04em;
    margin: 0;
    text-wrap: balance;
  }

  .forma-heading-outline {
    -webkit-text-stroke: 1.5px rgba(28,28,28,0.6);
    color: transparent;
    position: relative;
    z-index: 5;
  }

  .forma-heading-filled {
    color: #1C1C1C;
    -webkit-text-stroke: none;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 6;
    clip-path: circle(0% at 0% 100%);
    animation: forma-reveal 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }

  @keyframes forma-reveal {
    to {
      clip-path: circle(150% at 0% 100%);
    }
  }

  .forma-banner__metadata {
    position: absolute;
    top: 32px;
    right: 32px;
    z-index: 10;
    background: rgba(240, 237, 232, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 100px;
    padding: 10px 20px;
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 400;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #1C1C1C;
  }

  .forma-banner__buttons {
    display: flex;
    flex-direction: row;
    gap: 1.2rem;
    align-items: center;
  }

  .forma-banner__button {
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 500;
    font-size: 14px;
    padding: 13px 28px;
    border-radius: 100px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    border: none;
    cursor: pointer;
  }

  .forma-banner__button--primary {
    background: #1C1C1C;
    color: white;
  }

  .forma-banner__button--primary:hover {
    background: #2C2C2C;
    transform: translateY(-1px);
  }

  .forma-banner__button--ghost {
    background: rgba(240, 237, 232, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(28, 28, 28, 0.2);
    color: #1C1C1C;
  }

  .forma-banner__button--ghost:hover {
    background: rgba(240, 237, 232, 0.85);
    transform: translateY(-1px);
  }

  @media screen and (max-width: 749px) {
    .forma-banner {
      height: 60vh;
      min-height: 500px;
    }

    .forma-banner__content {
      padding: 0 24px 40px;
    }

    .forma-heading-outline,
    .forma-heading-filled {
      font-size: clamp(3rem, 8vw, 5rem);
    }

    .forma-heading-outline {
      -webkit-text-stroke: 1px rgba(28,28,28,0.6);
    }

    .forma-banner__metadata {
      top: 20px;
      right: 20px;
      font-size: 10px;
      padding: 8px 16px;
    }

    .forma-banner__buttons {
      flex-direction: column;
      align-items: stretch;
      gap: 0.8rem;
    }

    .forma-banner__button {
      text-align: center;
      font-size: 13px;
      padding: 12px 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .forma-heading-filled {
      animation: none;
      clip-path: circle(150% at 0% 100%);
    }
  }
{%- endstyle -%}

<section class="forma-banner">
  <div class="forma-banner__background">
    {%- if section.settings.image -%}
      {{- section.settings.image | image_url: width: 2400 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        width: section.settings.image.width,
        height: section.settings.image.height,
        alt: section.settings.image.alt | escape
      -}}
    {%- else -%}
      <div class="forma-banner__background-placeholder"></div>
    {%- endif -%}
  </div>

  <div class="forma-banner__metadata">
    Design Studio · London
  </div>

  <div class="forma-banner__content" data-forge-anim="fade-up">
    <div class="forma-banner__heading-wrapper">
      <h1 class="forma-heading-outline" data-forge-split="words" data-forge-split-anim="slide">
        {{- section.settings.heading | default: 'FORMA' -}}
      </h1>
      <h1 class="forma-heading-filled" aria-hidden="true">
        {{- section.settings.heading | default: 'FORMA' -}}
      </h1>
    </div>

    {%- if section.settings.button_label != blank or section.settings.button2_label != blank -%}
      <div class="forma-banner__buttons">
        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="forma-banner__button forma-banner__button--primary"
          >
            {{- section.settings.button_label -}}
          </a>
        {%- endif -%}
        {%- if section.settings.button2_label != blank -%}
          <a
            href="{{ section.settings.button2_link | default: '#' }}"
            class="forma-banner__button forma-banner__button--ghost"
          >
            {{- section.settings.button2_label -}}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FORMA"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary Button Label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "Secondary Button Label",
      "default": "About Studio"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Main Banner"
    }
  ]
}
{% endschema %}