<section style="position:relative;min-height:100svh;overflow:hidden;">
  {% if section.settings.image %}
    <img src="{{ section.settings.image | image_url: width: 2400 }}" srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1800 }} 1800w, {{ section.settings.image | image_url: width: 2400 }} 2400w" sizes="100vw" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;" loading="eager" alt="FORMA Studio lifestyle">
  {% else %}
    <div style="position:absolute;inset:0;background:#2A2A2A;"></div>
  {% endif %}
  <div style="position:absolute;inset:0;background:linear-gradient(to top right, rgba(0,0,0,0.38) 0%, rgba(0,0,0,0.05) 60%);"></div>
  <div style="position:absolute;bottom:60px;left:clamp(32px,5vw,80px);z-index:10;max-width:580px;">
    <div style="position:relative;margin-bottom:12px;">
      <h1 class="forma-heading-outline" style="font-family:'DM Sans',sans-serif;font-size:clamp(40px,5.5vw,72px);font-weight:300;letter-spacing:-0.01em;line-height:1.1;margin:0;color:transparent;-webkit-text-stroke:1px rgba(255,255,255,0.9);user-select:none;pointer-events:none;position:absolute;top:0;left:0;">{{ section.settings.heading | default: "Spaces Worth Living In." }}</h1>
      <h1 class="forma-heading-fill" style="font-family:'DM Sans',sans-serif;font-size:clamp(40px,5.5vw,72px);font-weight:300;letter-spacing:-0.01em;line-height:1.1;margin:0;color:#FFFFFF;clip-path:inset(0 100% 0 0);transition:clip-path 0.9s cubic-bezier(0.16,1,0.3,1) 0.5s;">{{ section.settings.heading | default: "Spaces Worth Living In." }}</h1>
    </div>
    <div style="margin-top:clamp(50px,6vw,90px);">
      <a href="/collections/all" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.12);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.32);color:#fff;text-decoration:none;padding:11px 24px;border-radius:100px;font-size:13px;font-family:'DM Sans',sans-serif;transition:background 0.2s;">Explore Collection →</a>
    </div>
  </div>
  <script>
  (function(){
    var fill = document.querySelector('.forma-heading-fill');
    if (!fill) return;
    requestAnimationFrame(function(){ setTimeout(function(){ fill.style.clipPath='inset(0 0% 0 0)'; }, 500); });
  })();
  </script>
</section>

{% schema %}
{
  "name": "Main Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle room photograph"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Spaces Worth Living In."
    }
  ],
  "presets": [
    {
      "name": "Main Banner"
    }
  ]
}
{% endschema %}